{
  "name": "@frc-attendance/kiosk",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "service": "tsx src/service/main.ts",
    "fingerprint:enroll": "python3 enroll_fingerprint.py",
    "fingerprint:map": "python3 enroll_fingerprint.py --map-only",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@frc-attendance/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "better-sqlite3": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  }
}
